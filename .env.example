# ══════════════════════════════════════════════════════════════════════════════
# .env.example — Copy to .env and fill in your values
# ══════════════════════════════════════════════════════════════════════════════

# ── LiveKit Cloud ───────────────────────────────────────────────────────────
# Get from: https://cloud.livekit.io/ → your project → Settings
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_SIP_DOMAIN=

# ── Google Gemini Live (LLM / STT / TTS) ────────────────────────────────────
# Get from: https://aistudio.google.com/
GOOGLE_API_KEY=

# ── Telnyx (Telephony) ──────────────────────────────────────────────────────
# Get from: https://portal.telnyx.com/
TELNYX_API_KEY=
TELNYX_CONNECTION_ID=
TELNYX_SIP_TRUNK_ID=
TELNYX_OUTBOUND_NUMBER=
DEPLOYMENT_MARKET=US

# ── Cal.com (Booking) ───────────────────────────────────────────────────────
# Get from: https://app.cal.com/settings/developer/api-keys
CAL_API_KEY=
CAL_EVENT_TYPE_ID=

# ── Supabase (Database) ─────────────────────────────────────────────────────
# Get from: https://app.supabase.com/ → your project → Settings → API
SUPABASE_URL=
SUPABASE_KEY=

# ── Supabase S3 (Call Recordings) ───────────────────────────────────────────
# Get from: Supabase Dashboard → Storage → Settings → S3 Access → Generate key
# Bucket: create a private bucket named 'call-recordings' in Storage
SUPABASE_S3_ACCESS_KEY=
SUPABASE_S3_SECRET_KEY=
SUPABASE_S3_ENDPOINT=
SUPABASE_S3_REGION=ap-south-1

# ── Telegram Notifications ──────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram, then get your Chat ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Call Transfer ────────────────────────────────────────────────────────────
# Phone number to transfer calls to (human agent fallback)
DEFAULT_TRANSFER_NUMBER=
